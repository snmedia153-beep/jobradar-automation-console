# JobRadar local/Docker configuration example
# Copy this file to .env before running Docker Compose.

# Collection defaults
TARGET_URL=https://m.saramin.co.kr/location-job/recently-list?is_detail_search=y&list_type=domestic&loc_cd=102020%2C102030%2C102040%2C102050
HEADLESS=false
MAX_ITEMS=50
SCROLL_TIMES=6
REQUEST_DELAY_MS=1200
DETAIL_DELAY_MS=800
DEFAULT_CAMPAIGN_NAME=IT 채용 모니터링

# Storage
OUTPUT_DIR=/app/output
DATABASE_BACKEND=postgres
DATABASE_URL=postgresql://jobradar:change_me@postgres:5432/jobradar
POSTGRES_DB=jobradar
POSTGRES_USER=jobradar
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5432

# Redis / queue
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
REDIS_QUEUE_ENABLED=true
REDIS_KEY_PREFIX=jobradar
REDIS_EVENTS_MAXLEN=500
JOBRADAR_DOCKER_MODE=true

# API / GUI
JOBRADAR_API_PORT=8000
JOBRADAR_GUI_PORT=8501
JOBRADAR_API_ENABLED=true
JOBRADAR_API_URL=http://jobradar-api:8000
JOBRADAR_GUI_URL=http://127.0.0.1:8501

# Windows Host Agent
JOBRADAR_HOST_AGENT_ENABLED=true
JOBRADAR_HOST_AGENT_URL=http://host.docker.internal:8767
JOBRADAR_HOST_AGENT_PORT=8767
JOBRADAR_HOST_AGENT_TIMEOUT_SECONDS=8

# Android SDK paths on the Windows host
ANDROID_HOME=C:\Users\YOUR_NAME\AppData\Local\Android\Sdk
ANDROID_SDK_ROOT=C:\Users\YOUR_NAME\AppData\Local\Android\Sdk
ADB_PATH=C:\Users\YOUR_NAME\AppData\Local\Android\Sdk\platform-tools\adb.exe
EMULATOR_PATH=C:\Users\YOUR_NAME\AppData\Local\Android\Sdk\emulator\emulator.exe

# Device slots
EMULATOR_SLOTS=5
EMULATOR_PORT_PAIRS=5554:5555,5656:5657,5658:5659,5660:5661
EMULATOR_GPU_MODE=swiftshader_indirect
EMULATOR_LAUNCH_DELAY_SECONDS=8
EMULATOR_BOOT_TIMEOUT_SECONDS=240

# Appium ports
APPIUM_HOST=host.docker.internal
APPIUM_CONNECT_HOST=host.docker.internal
APPIUM_BASE_PORT=4723
APPIUM_PORT_STEP=2
APPIUM_PORTS=4723,4725,4727,4729,4731
APPIUM_STATUS_PORTS=4723,4725,4727,4729,4731
USB_APPIUM_PORT=4731
APPIUM_SYSTEM_PORT_BASE=8201
APPIUM_MJPEG_PORT_BASE=9201
APPIUM_CHROMEDRIVER_PORT_BASE=9515
APPIUM_SERVER_URL=http://127.0.0.1:4723

# Appium behavior
APPIUM_BROWSER_NAME=Chrome
APPIUM_BROWSER_PACKAGE=com.android.chrome
ANDROID_DEVICE_NAME=Android Emulator
ANDROID_SETTINGS_PACKAGE=com.android.settings
ANDROID_SETTINGS_ACTIVITY=.Settings
APPIUM_NEW_COMMAND_TIMEOUT=180
APPIUM_PAGE_LOAD_TIMEOUT=60
APPIUM_STEP_DELAY_MS=1200
APPIUM_AUTO_ACCEPT_ALERTS=true
APPIUM_CHROMEDRIVER_AUTODOWNLOAD=true
APPIUM_ALLOW_INSECURE=*:chromedriver_autodownload
APPIUM_COMMAND=appium

# Worker stability
WORKER_POLL_SECONDS=5
WORKER_HEARTBEAT_SECONDS=10
WORKER_STALE_AFTER_SECONDS=180
WORKER_RETRY_DELAY_SECONDS=30
WORKER_AUTO_RETRY=true
SLOT_LOG_TAIL_LINES=200

# Optional notification channels
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=

# Optional UI/runtime values
VIEWPORT_WIDTH=390
VIEWPORT_HEIGHT=844
TESSERACT_CMD=
WORKER_ID=
USER_AGENT=Mozilla/5.0 (iPhone; CPU iPhone OS 17_0 like Mac OS X) AppleWebKit/605.1.15 (KHTML, like Gecko) Version/17.0 Mobile/15E148 Safari/604.1
